DYNAMIC_ALERT_ENV=development
DYNAMIC_ALERT_DATABASE_URL=sqlite:///./dynamic_alert.db
DYNAMIC_ALERT_CONTROL_PLANE_URL=http://127.0.0.1:8000
DYNAMIC_ALERT_EDGE_NODE_KEY=
DYNAMIC_ALERT_EDGE_NODE_NAME=edge-node-local
DYNAMIC_ALERT_EDGE_SITE_CODE=
DYNAMIC_ALERT_EDGE_POLL_INTERVAL_SECONDS=5.0
DYNAMIC_ALERT_TELEGRAM_BOT_TOKEN=
DYNAMIC_ALERT_TELEGRAM_CHAT_ID=
DYNAMIC_ALERT_TELEGRAM_API_BASE=https://api.telegram.org
DYNAMIC_ALERT_TELEGRAM_TIMEOUT_SECONDS=5.0
DYNAMIC_ALERT_SCAN_SUBNETS=192.168.1.0/24
DYNAMIC_ALERT_API_CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
DYNAMIC_ALERT_BOOTSTRAP_API_KEY=change-me-before-production
DYNAMIC_ALERT_LOCAL_AI_ENABLED=true
DYNAMIC_ALERT_LOCAL_AI_MODEL_NAME=semantic-heuristic-v1
DYNAMIC_ALERT_LOCAL_AI_ONLINE_LEARNING_ENABLED=true
DYNAMIC_ALERT_MODBUS_PROFILES_PATH=configs/modbus_profiles.json
DYNAMIC_ALERT_MODBUS_TIMEOUT_SECONDS=1.0
DYNAMIC_ALERT_MODBUS_GENERIC_PROBE_ENABLED=true
DYNAMIC_ALERT_MODBUS_GENERIC_PROBE_COUNT=4
DYNAMIC_ALERT_MQTT_PROBE_TOPICS=#
DYNAMIC_ALERT_MQTT_PROBE_TIMEOUT_SECONDS=2.0
DYNAMIC_ALERT_MQTT_PROBE_MAX_MESSAGES=3
DYNAMIC_ALERT_SNMP_COMMUNITY=public
DYNAMIC_ALERT_SNMP_TIMEOUT_SECONDS=1.0
DYNAMIC_ALERT_SNMP_PORT=161
DYNAMIC_ALERT_PACKET_CAPTURE_INTERFACE=
DYNAMIC_ALERT_PACKET_CAPTURE_TIMEOUT_SECONDS=5.0
DYNAMIC_ALERT_PACKET_CAPTURE_MAX_PACKETS=100
DYNAMIC_ALERT_PACKET_CAPTURE_BPF_FILTER=tcp or udp
DYNAMIC_ALERT_PACKET_CAPTURE_INCLUDE_LINK_LOCAL=false
